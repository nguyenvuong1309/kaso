    "cloudSync.header.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sync your encrypted data across iPhone, iPad and Mac. Nothing ever leaves your devices unencrypted." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Đồng bộ dữ liệu đã mã hoá giữa iPhone, iPad và Mac. Không gì rời thiết bị dưới dạng chưa mã hoá." } }
      }
    },
    "cloudSync.header.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "iCloud sync" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Đồng bộ iCloud" } }
      }
    },
    "cloudSync.privacy.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kaso encrypts every record on-device with a key stored in your Keychain. iCloud only ever sees encrypted blobs." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Kaso mã hoá mọi bản ghi trên máy bằng khoá lưu trong Keychain. iCloud chỉ thấy dữ liệu đã mã hoá." } }
      }
    },
    "cloudSync.privacy.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "End-to-end encrypted" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Mã hoá đầu cuối" } }
