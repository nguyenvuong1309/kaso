            "state" : "translated",
            "value" : "Kỳ vọng hỗ trợ gia đình khác nhau"
          }
        }
      }
    },
    "compatibility.conflict.futureGoals.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long-term priorities are not aligned yet. Convert goals into dates, amounts, and trade-offs so both sides can compare clearly."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ưu tiên dài hạn chưa cùng hướng. Hãy biến mục tiêu thành thời hạn, số tiền và đánh đổi cụ thể để so sánh rõ ràng."
          }
        }
      }
    },
