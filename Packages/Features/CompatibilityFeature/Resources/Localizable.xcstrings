    "compatibility.conflict.debtAttitude.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One person may see debt as a useful tool while the other treats it as something to avoid. Agree on clear debt limits before big decisions."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Một người có thể xem nợ là công cụ, người còn lại muốn tránh nợ. Hãy thống nhất giới hạn nợ trước các quyết định lớn."
          }
        }
      }
    },
    "compatibility.conflict.debtAttitude.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Different debt comfort levels"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khác mức thoải mái với nợ"
          }
        }
      }
    },
    "compatibility.conflict.empty" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No major conflict areas detected. Keep the conversation open before large shared commitments."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chưa thấy vùng xung đột lớn. Vẫn nên nói chuyện rõ trước các cam kết tài chính chung."
          }
        }
      }
    },
    "compatibility.conflict.familySupport.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Family support can create pressure if expectations are unclear. Define monthly boundaries and emergency rules together."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hỗ trợ gia đình dễ tạo áp lực nếu kỳ vọng chưa rõ. Hãy thống nhất hạn mức tháng và nguyên tắc cho trường hợp khẩn cấp."
          }
        }
      }
    },
    "compatibility.conflict.familySupport.title" : {
