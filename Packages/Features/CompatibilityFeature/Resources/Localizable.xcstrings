        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rủi ro đầu tư có thể hấp dẫn với một người nhưng bất an với người kia. Hãy tách tiền khẩn cấp khỏi phần vốn chấp nhận rủi ro."
          }
