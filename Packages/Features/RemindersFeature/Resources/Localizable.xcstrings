    },
    "reminders.kind.endOfDayEntry.description" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If you haven't logged anything today, get a friendly nudge before bedtime." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Nếu hôm nay bạn chưa ghi gì, app sẽ nhắc nhẹ trước khi đi ngủ." } }
