    "reminders.header.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pick the nudges you want. Notification bodies don't contain amounts or transaction details." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Chọn các nhắc nhở bạn muốn. Nội dung thông báo không chứa số tiền hay chi tiết giao dịch." } }
