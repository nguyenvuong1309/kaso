    "sleep.permission.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaso reads sleep data from HealthKit and analyzes it locally with your spending history. Health data is not stored by Kaso."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaso đọc dữ liệu ngủ từ HealthKit và phân tích cục bộ với lịch sử chi tiêu. Kaso không lưu dữ liệu sức khoẻ."
          }
        }
      }
    },
