    "seasonalPlanner.header.hasSpike" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Heads up — your history shows higher spending coming up. Start setting aside money each week to avoid a cash crunch." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Lịch sử cho thấy bạn sắp vào mùa chi nhiều. Để dành mỗi tuần để không bị động." } }
      }
    },
    "seasonalPlanner.header.noSpike" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No big spending peaks predicted in the next two months." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Không có mùa chi đột biến trong 2 tháng tới." } }
      }
    },
    "seasonalPlanner.header.insufficient" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "We need at least two years of history to detect seasons accurately." } },
